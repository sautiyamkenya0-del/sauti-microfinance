insert into public.system_outflows (
  id, kind, amount, receiver_name, receiver_phone, method, supplier_id, loan_id,
  transaction_id, note, by_staff, created_at
)
select
  'OUT-LEADWAY-' || coalesce(member_id, replace(lower(member_name),' ','-')) || '-' || to_char(entry_date::date,'YYYYMMDD'),
  'supplier_payment',
  amount,
  'LEAD WAY PETROL STATION',
  '0700000000',
  'mpesa',
  'SUP-LEAD-WAY-PETROL',
  'LW-FUEL-' || coalesce(member_id, replace(lower(member_name),' ','-')) || '-' || to_char(entry_date::date,'YYYYMMDD'),
  null,
  'Sauti payment to Lead Way for member fuel consumption. Member owes Sauti through the linked fuel loan.',
  'S1',
  now()
from fuel_out
on conflict (id) do update set
  amount = excluded.amount,
  note = excluded.note;

commit;