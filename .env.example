# Copy this file to .env and provide your real environment secrets.
# Do NOT commit .env or any real secret values to git.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SAUTI_SESSION_SECRET="replace-with-a-long-random-session-secret"

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

MPESA_ENV="production"
MPESA_SHORTCODE="your-paybill-or-till"
MPESA_CONSUMER_KEY="your-daraja-consumer-key"
MPESA_CONSUMER_SECRET="your-daraja-consumer-secret"
MPESA_PASSKEY="your-daraja-passkey"

# Keep production diagnostics disabled unless you are actively troubleshooting.
SAUTI_ENABLE_MPESA_DIAGNOSTICS="false"
