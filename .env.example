# Copy this file to .env and provide your real environment secrets.
# Do NOT commit .env or any real secret values to git.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SAUTI_SESSION_SECRET="replace-with-a-long-random-session-secret"

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

MPESA_ENV="production"
MPESA_SHORTCODE="your-paybill-or-till"
MPESA_CONSUMER_KEY="your-daraja-consumer-key"
MPESA_CONSUMER_SECRET="your-daraja-consumer-secret"
MPESA_PASSKEY="your-daraja-passkey"

# These legacy MySQL settings are optional and only required for the old
# `api_topups` sync feature.
# If your Vercel deployment cannot connect directly to cPanel MySQL,
# leave these values unset and use Supabase-only mode in production.
#
# If you do want legacy sync, use the actual MySQL host from cPanel/hosting
# and allow a stable remote IP in cPanel Remote MySQL / Access Host.
# Vercel serverless outbound IPs are not fixed, so direct MySQL access often
# does not work reliably from Vercel. Instead use a local machine or proxy/VPS.
# You can run `npm run legacy-topup-bridge` on that machine and point the app
# at it with OLD_DB_BRIDGE_URL.
OLD_DB_BRIDGE_URL=""
OLD_DB_BRIDGE_KEY=""
OLD_DB_BRIDGE_BIND="127.0.0.1"
OLD_DB_BRIDGE_PORT="8788"
OLD_DB_CONNECT_TIMEOUT_MS="10000"
OLD_DB_QUERY_TIMEOUT_MS="15000"
OLD_DB_BRIDGE_TIMEOUT_MS="15000"
OLD_DB_HOST="your-cpanel-mysql-host"
OLD_DB_PORT="3306"
OLD_DB_NAME="your-cpanel-db-name"
OLD_DB_USER="your-cpanel-db-user"
OLD_DB_PASS="your-old-db-password"
# Defaults to `api_topup` and will also auto-try `api_topups` if needed.
OLD_DB_TOPUP_TABLE="api_topup"

# Optional overrides if api_topup uses non-standard column names.
OLD_DB_TOPUP_ID_COLUMN=""
OLD_DB_TOPUP_AMOUNT_COLUMN=""
OLD_DB_TOPUP_ACCOUNT_COLUMN=""
OLD_DB_TOPUP_MEMBER_COLUMN=""
OLD_DB_TOPUP_REF_COLUMN=""
OLD_DB_TOPUP_PHONE_COLUMN=""
OLD_DB_TOPUP_PAYER_COLUMN=""
OLD_DB_TOPUP_CREATED_AT_COLUMN=""
OLD_DB_TOPUP_STATUS_COLUMN=""

# Keep production diagnostics disabled unless you are actively troubleshooting.
SAUTI_ENABLE_MPESA_DIAGNOSTICS="false"
